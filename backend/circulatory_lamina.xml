<?xml version="1.0" encoding="UTF-8"?>
<!--
  Circulatory Lamina - Attribute Definition File
  
  This XML file defines ALL attributes, their metadata, dependencies,
  and mappings to function models. Domain experts can modify this file
  to adjust the model without touching Python code.
  
  Structure:
    <lamina>
      <attributes>     - All measurable/computed values
      <functions>       - All computational models
      <composites>      - Logical groupings for vector space
      <gates>           - Permeability gate conditions
    </lamina>
-->

<lamina name="Circulatory" id="lamina_circulatory" version="2.0" level="1">

  <upper_lamina id="none" />
  <lower_lamina id="none" />

  <!-- ============================================================== -->
  <!-- CHANNEL MAPPINGS: Links sensor attributes to ingestion channels -->
  <!-- Channel definitions live in ingestion_manifold.xml            -->
  <!-- ============================================================== -->
  <channel_mappings>
    <mapping attribute_id="SBP"  channel_id="ch_manual_slider" />
    <mapping attribute_id="DBP"  channel_id="ch_manual_slider" />
    <mapping attribute_id="HR"   channel_id="ch_manual_slider" />
    <mapping attribute_id="eta"  channel_id="ch_manual_slider" />
    <mapping attribute_id="L"    channel_id="ch_manual_slider" />
    <mapping attribute_id="r"    channel_id="ch_manual_slider" />
    <mapping attribute_id="EDV"  channel_id="ch_manual_slider" />
    <mapping attribute_id="r_m"  channel_id="ch_manual_slider" />
    <mapping attribute_id="r_i"  channel_id="ch_manual_slider" />
    <mapping attribute_id="r_e"  channel_id="ch_manual_slider" />
  </channel_mappings>

  <!-- ============================================================== -->
  <!-- ATTRIBUTES: Each attribute is an object with full metadata      -->
  <!-- source: SENSOR = external measurement, PRELIMINARY = computed   -->
  <!-- ============================================================== -->
  <attributes>

    <!-- SENSOR ATTRIBUTES (external inputs) -->
    <attribute id="SBP">
      <name>Systolic Blood Pressure</name>
      <unit>mmHg</unit>
      <source>SENSOR</source>
      <physio_min>90</physio_min>
      <physio_max>180</physio_max>
      <description>Peak pressure during ventricular contraction</description>
    </attribute>

    <attribute id="DBP">
      <name>Diastolic Blood Pressure</name>
      <unit>mmHg</unit>
      <source>SENSOR</source>
      <physio_min>60</physio_min>
      <physio_max>120</physio_max>
      <description>Minimum pressure during ventricular relaxation</description>
    </attribute>

    <attribute id="eta">
      <name>Blood Viscosity</name>
      <unit>mPa.s</unit>
      <source>SENSOR</source>
      <physio_min>3.0</physio_min>
      <physio_max>4.0</physio_max>
      <description>Dynamic viscosity of blood</description>
    </attribute>

    <attribute id="L">
      <name>Vessel Length</name>
      <unit>cm</unit>
      <source>SENSOR</source>
      <physio_min>1.0</physio_min>
      <physio_max>100.0</physio_max>
      <description>Length of the vessel segment being modelled</description>
    </attribute>

    <attribute id="r">
      <name>Vessel Radius</name>
      <unit>cm</unit>
      <source>SENSOR</source>
      <physio_min>0.01</physio_min>
      <physio_max>1.5</physio_max>
      <description>Internal radius of the vessel</description>
    </attribute>

    <attribute id="EDV">
      <name>End-Diastolic Volume</name>
      <unit>mL</unit>
      <source>SENSOR</source>
      <physio_min>50</physio_min>
      <physio_max>250</physio_max>
      <description>Volume of blood in ventricle before contraction</description>
    </attribute>

    <attribute id="HR">
      <name>Heart Rate</name>
      <unit>bpm</unit>
      <source>SENSOR</source>
      <physio_min>40</physio_min>
      <physio_max>200</physio_max>
      <description>Heart rate from Apple Watch</description>
    </attribute>

    <attribute id="r_m">
      <name>Membrane Resistance</name>
      <unit>ohm.cm</unit>
      <source>SENSOR</source>
      <physio_min>1000</physio_min>
      <physio_max>10000</physio_max>
      <description>Resistance of the cell membrane</description>
    </attribute>

    <attribute id="r_i">
      <name>Intracellular Resistance</name>
      <unit>ohm.cm</unit>
      <source>SENSOR</source>
      <physio_min>100</physio_min>
      <physio_max>500</physio_max>
      <description>Resistance inside the cell</description>
    </attribute>

    <attribute id="r_e">
      <name>Extracellular Resistance</name>
      <unit>ohm.cm</unit>
      <source>SENSOR</source>
      <physio_min>100</physio_min>
      <physio_max>500</physio_max>
      <description>Resistance of extracellular space</description>
    </attribute>

    <!-- PRELIMINARY ATTRIBUTES (computed internally) -->
    <attribute id="MAP">
      <name>Mean Arterial Pressure</name>
      <unit>mmHg</unit>
      <source>PRELIMINARY</source>
      <physio_min>60</physio_min>
      <physio_max>110</physio_max>
      <computed_by>pressure_regulation</computed_by>
      <depends_on>SBP, DBP</depends_on>
      <description>Average driving pressure across cardiac cycle</description>
    </attribute>

    <attribute id="R">
      <name>Vascular Resistance</name>
      <unit>mmHg.min/L</unit>
      <source>PRELIMINARY</source>
      <physio_min>10</physio_min>
      <physio_max>40</physio_max>
      <computed_by>vascular_resistance</computed_by>
      <depends_on>eta, L, r</depends_on>
      <description>Resistance to blood flow from vessel properties</description>
    </attribute>

    <attribute id="SV">
      <name>Stroke Volume</name>
      <unit>mL</unit>
      <source>PRELIMINARY</source>
      <physio_min>30</physio_min>
      <physio_max>150</physio_max>
      <computed_by>cardiac_filling</computed_by>
      <depends_on>EDV</depends_on>
      <description>Volume of blood pumped per heartbeat</description>
    </attribute>

    <attribute id="CO">
      <name>Cardiac Output</name>
      <unit>L/min</unit>
      <source>PRELIMINARY</source>
      <physio_min>2</physio_min>
      <physio_max>12</physio_max>
      <computed_by>cardiac_pump</computed_by>
      <depends_on>HR, SV</depends_on>
      <description>Total blood output per minute</description>
    </attribute>

    <attribute id="Q">
      <name>Blood Flow Rate</name>
      <unit>L/min</unit>
      <source>PRELIMINARY</source>
      <physio_min>0.5</physio_min>
      <physio_max>15</physio_max>
      <computed_by>hemodynamic_flow</computed_by>
      <depends_on>MAP, R</depends_on>
      <description>Actual blood flow through circulation (primary output)</description>
    </attribute>

    <attribute id="lambda">
      <name>Length Constant</name>
      <unit>mm</unit>
      <source>PRELIMINARY</source>
      <physio_min>0.5</physio_min>
      <physio_max>5.0</physio_max>
      <computed_by>electrical_conduction</computed_by>
      <depends_on>r_m, r_i, r_e</depends_on>
      <description>Signal propagation distance before decay</description>
    </attribute>

  </attributes>

  <!-- ============================================================== -->
  <!-- FUNCTIONS: Computational models (mapped to Python methods)       -->
  <!-- Domain experts can add new functions or modify step order here  -->
  <!-- ============================================================== -->
  <functions>

    <function id="pressure_regulation" step="1">
      <name>Pressure Regulation</name>
      <formula>MAP = (1/3)*SBP + (2/3)*DBP</formula>
      <inputs>SBP, DBP</inputs>
      <output>MAP</output>
      <description>Computes mean arterial pressure. DBP weighted 2/3 because diastole is ~2x longer than systole.</description>
    </function>

    <function id="vascular_resistance" step="2">
      <name>Vascular Resistance</name>
      <formula>R = 8*eta*L / (pi * r^4)</formula>
      <inputs>eta, L, r</inputs>
      <output>R</output>
      <description>Poiseuille's Law. r^4 dependence: 50% radius reduction = 16x resistance increase.</description>
    </function>

    <function id="cardiac_filling" step="3a">
      <name>Cardiac Filling</name>
      <formula>SV = k * EDV (with Starling limit)</formula>
      <inputs>EDV</inputs>
      <output>SV</output>
      <description>Frank-Starling Law. Heart pumps what it receives, capped at physiological limit.</description>
    </function>

    <function id="cardiac_pump" step="3b">
      <name>Cardiac Pump</name>
      <formula>CO = HR * SV / 1000</formula>
      <inputs>HR, SV</inputs>
      <output>CO</output>
      <description>Primary pump output. HR from Apple Watch, SV from cardiac_filling.</description>
    </function>

    <function id="hemodynamic_flow" step="4">
      <name>Hemodynamic Flow</name>
      <formula>Q = delta_P / R</formula>
      <inputs>MAP, R</inputs>
      <output>Q</output>
      <description>Ohm's Law for hemodynamics. Central formula resolving pressure and resistance into flow.</description>
    </function>

    <function id="electrical_conduction" step="5">
      <name>Electrical Conduction</name>
      <formula>lambda = sqrt(r_m / (r_i + r_e))</formula>
      <inputs>r_m, r_i, r_e</inputs>
      <output>lambda</output>
      <description>Cable Theory. Models signal propagation distance. Links to ECG P-wave analysis.</description>
    </function>

  </functions>

  <!-- ============================================================== -->
  <!-- COMPOSITES: Logical groupings for vector space representation   -->
  <!-- ============================================================== -->
  <composites>

    <!--
      absorption_vector: 1D seed weights, one per attribute in order.
      Values are 1/N (equal) — the Auto Controller adjusts these dynamically
      via W_new = W_old + (learning_rate × deviation) after each feedback cycle.
    -->

    <composite id="pressure_state">
      <name>Pressure State</name>
      <attributes>SBP, DBP, MAP</attributes>
      <description>Represents the lamina's pressure condition</description>
      <absorption_vector>
        <weight attribute="SBP">0.3333</weight>
        <weight attribute="DBP">0.3333</weight>
        <weight attribute="MAP">0.3333</weight>
      </absorption_vector>
    </composite>

    <composite id="vessel_state">
      <name>Vessel State</name>
      <attributes>eta, L, r, R</attributes>
      <description>Represents vessel geometry and resistance</description>
      <absorption_vector>
        <weight attribute="eta">0.25</weight>
        <weight attribute="L">0.25</weight>
        <weight attribute="r">0.25</weight>
        <weight attribute="R">0.25</weight>
      </absorption_vector>
    </composite>

    <composite id="pump_state">
      <name>Pump State</name>
      <attributes>EDV, SV, HR, CO</attributes>
      <description>Represents cardiac pump function</description>
      <absorption_vector>
        <weight attribute="EDV">0.25</weight>
        <weight attribute="SV">0.25</weight>
        <weight attribute="HR">0.25</weight>
        <weight attribute="CO">0.25</weight>
      </absorption_vector>
    </composite>

    <composite id="flow_state">
      <name>Flow State</name>
      <attributes>Q</attributes>
      <description>Primary output - circulatory flow</description>
      <absorption_vector>
        <weight attribute="Q">1.0</weight>
      </absorption_vector>
    </composite>

    <composite id="conduction_state">
      <name>Conduction State</name>
      <attributes>r_m, r_i, r_e, lambda</attributes>
      <description>Electrical signal propagation state</description>
      <absorption_vector>
        <weight attribute="r_m">0.25</weight>
        <weight attribute="r_i">0.25</weight>
        <weight attribute="r_e">0.25</weight>
        <weight attribute="lambda">0.25</weight>
      </absorption_vector>
    </composite>

  </composites>

  <!-- ============================================================== -->
  <!-- GATES: Permeability conditions for each attribute               -->
  <!-- Domain experts can adjust thresholds here                       -->
  <!-- ============================================================== -->
  <gates>

    <gate attribute="MAP" type="range">
      <min>60</min>
      <max>110</max>
      <action_on_fail>hold_previous</action_on_fail>
      <flag>hypo/hypertension alert</flag>
    </gate>

    <gate attribute="R" type="positive">
      <min>0</min>
      <action_on_fail>hold_previous</action_on_fail>
      <flag>invalid resistance</flag>
    </gate>

    <gate attribute="CO" type="range">
      <min>2</min>
      <max>12</max>
      <action_on_fail>hold_previous</action_on_fail>
      <flag>abnormal cardiac output</flag>
    </gate>

    <gate attribute="Q" type="range">
      <min>0.5</min>
      <max>15</max>
      <action_on_fail>hold_previous</action_on_fail>
      <flag>abnormal flow rate</flag>
    </gate>

    <gate attribute="Q_CO_match" type="consistency">
      <tolerance>0.10</tolerance>
      <compare>Q, CO</compare>
      <action_on_fail>recalibrate</action_on_fail>
      <flag>Q != CO: model inconsistency</flag>
    </gate>

  </gates>

  <!-- ============================================================== -->
  <!-- SEGMENTS: Named sub-sections of this lamina                    -->
  <!-- Each segment groups related attributes, composites, functions  -->
  <!-- absorption_vector and behavioural_outcomes: PENDING definition -->
  <!-- ============================================================== -->
  <segments>

    <!--
      behavioural_outcomes: domain-expert defined numerical targets.
      Each outcome produces a Feedback Object when evaluated:
        { target, actual, deviation, deviation_pct, within_tolerance, status }
      The Auto Controller reads deviation to compute ΔW for weight adjustment.
      Target values are standard healthy resting ranges (clinical reference).
    -->

    <segment name="Arterial" id="seg_arterial">
      <description>Systemic arterial circulation subsystem</description>
      <attributes>SBP, DBP, MAP, R, Q</attributes>
      <composites>pressure_state, vessel_state, flow_state</composites>
      <functions>pressure_regulation, vascular_resistance, hemodynamic_flow</functions>
      <behavioural_outcomes>
        <outcome id="target_flow" attribute="Q" target="5.5" tolerance="1.5"
                 name="Target Flow Rate" unit="L/min">
          <description>Normal resting cardiac flow 4.0–7.0 L/min</description>
        </outcome>
        <outcome id="target_map" attribute="MAP" target="85" tolerance="15"
                 name="Target Mean Arterial Pressure" unit="mmHg">
          <description>Healthy MAP range 70–100 mmHg</description>
        </outcome>
      </behavioural_outcomes>
    </segment>

    <segment name="Cardiac" id="seg_cardiac">
      <description>Cardiac pump subsystem</description>
      <attributes>EDV, HR, SV, CO</attributes>
      <composites>pump_state</composites>
      <functions>cardiac_filling, cardiac_pump</functions>
      <behavioural_outcomes>
        <outcome id="target_co" attribute="CO" target="5.0" tolerance="1.5"
                 name="Target Cardiac Output" unit="L/min">
          <description>Normal resting cardiac output 4.0–8.0 L/min</description>
        </outcome>
        <outcome id="target_sv" attribute="SV" target="70" tolerance="15"
                 name="Target Stroke Volume" unit="mL">
          <description>Normal resting stroke volume 55–85 mL</description>
        </outcome>
      </behavioural_outcomes>
    </segment>

    <segment name="Conduction" id="seg_conduction">
      <description>Electrical conduction subsystem</description>
      <attributes>r_m, r_i, r_e, lambda</attributes>
      <composites>conduction_state</composites>
      <functions>electrical_conduction</functions>
      <behavioural_outcomes>
        <outcome id="target_lambda" attribute="lambda" target="2.0" tolerance="0.5"
                 name="Target Length Constant" unit="mm">
          <description>Normal propagation distance 1.5–2.5 mm; below 0.5 mm signals arrhythmia risk</description>
        </outcome>
      </behavioural_outcomes>
    </segment>

  </segments>

</lamina>
